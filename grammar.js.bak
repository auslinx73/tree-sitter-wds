/// <reference types="tree-sitter-cli/dsl" />
// @ts-check
//
// Tree-sitter grammar for Widget Designer Script (WDS)
// Based on official Christie Pandoras Box / Widget Designer 6.6.2 documentation
//

module.exports = grammar({
  name: "wds",

  extras: ($) => [/\s/, $.comment],

  word: ($) => $.identifier,

  conflicts: ($) => [
    [$.primary_expression, $.lvalue],
    [$.member_expression, $.lvalue],
    [$.subscript_expression, $.lvalue],
  ],

  rules: {
    // ─── Program ──────────────────────────────────────────────
    source_file: ($) => repeat($._statement),

    _statement: ($) =>
      choice(
        $.variable_declaration,
        $.if_statement,
        $.switch_statement,
        $.for_statement,
        $.foreach_statement,
        $.return_statement,
        $.break_statement,
        $.exit_statement,
        $.compound_assignment,
        $.assignment_statement,
        $.expression_statement,
      ),

    // ─── Comments ─────────────────────────────────────────────
    comment: ($) =>
      token(
        choice(
          seq("//", /[^\r\n]*/),
          seq("/*", /[^*]*\*+([^/*][^*]*\*+)*/, "/"),
        ),
      ),

    // ─── Variable Declaration ─────────────────────────────────
    variable_declaration: ($) =>
      seq(
        choice("var", "Var", "VAR"),
        field("name", $.identifier),
        optional(seq("=", field("value", $._expression))),
      ),

    // ─── Assignment ───────────────────────────────────────────
    assignment_statement: ($) =>
      prec(1, seq(field("left", $.lvalue), "=", field("right", $._expression))),

    lvalue: ($) =>
      choice($.identifier, $.member_expression, $.subscript_expression),

    // ─── Compound Assignment ──────────────────────────────────
    compound_assignment: ($) =>
      prec(
        2,
        seq(
          field("left", $.lvalue),
          field("operator", choice("+=", "-=", "*=", "/=")),
          field("right", $._expression),
        ),
      ),

    // ─── If / ElseIf / Else ───────────────────────────────────
    if_statement: ($) =>
      seq(
        choice("if", "If", "IF"),
        field("condition", $._expression),
        field("consequence", $.block),
        repeat($.elseif_clause),
        optional($.else_clause),
      ),

    elseif_clause: ($) =>
      seq(
        choice("elseif", "ElseIf", "ELSEIF", "Elseif"),
        field("condition", $._expression),
        field("consequence", $.block),
      ),

    else_clause: ($) =>
      seq(choice("else", "Else", "ELSE"), field("body", $.block)),

    // ─── Switch / Case / Case Else ────────────────────────────
    switch_statement: ($) =>
      seq(
        choice("switch", "Switch", "SWITCH"),
        field("value", $._expression),
        "{",
        repeat($.case_clause),
        optional($.case_else_clause),
        "}",
      ),

    case_clause: ($) =>
      seq(
        choice("case", "Case", "CASE"),
        field("value", $._expression),
        field("body", repeat($._statement)),
      ),

    case_else_clause: ($) =>
      seq(
        choice("case", "Case", "CASE"),
        choice("else", "Else", "ELSE"),
        field("body", repeat($._statement)),
      ),

    // ─── For Loop ─────────────────────────────────────────────
    for_statement: ($) =>
      seq(
        choice("for", "For", "FOR"),
        field("variable", $.identifier),
        "=",
        field("start", $._expression),
        choice("to", "To", "TO"),
        field("end", $._expression),
        optional(
          seq(choice("step", "Step", "STEP"), field("step", $._expression)),
        ),
        field("body", $.block),
      ),

    // ─── ForEach Loop ─────────────────────────────────────────
    foreach_statement: ($) =>
      seq(
        choice("foreach", "ForEach", "FOREACH", "Foreach"),
        field("variable", $.identifier),
        choice("in", "In", "IN"),
        field("iterable", $._expression),
        field("body", $.block),
      ),

    // ─── Return / Break / Exit ────────────────────────────────
    return_statement: ($) =>
      seq(choice("return", "Return", "RETURN"), optional($._expression)),

    break_statement: ($) => choice("break", "Break", "BREAK"),

    exit_statement: ($) => choice("exit", "Exit", "EXIT"),

    // ─── Block ────────────────────────────────────────────────
    block: ($) => seq("{", repeat($._statement), "}"),

    // ─── Expression Statement ─────────────────────────────────
    expression_statement: ($) => $._expression,

    // ─── Expressions ──────────────────────────────────────────
    _expression: ($) =>
      choice(
        $.binary_expression,
        $.unary_expression,
        $.primary_expression,
        $.parenthesized_expression,
      ),

    parenthesized_expression: ($) => seq("(", $._expression, ")"),

    // ─── Binary Expression ────────────────────────────────────
    binary_expression: ($) =>
      choice(
        // Logical AND / OR
        prec.left(
          1,
          seq(
            field("left", $._expression),
            choice("and", "And", "AND"),
            field("right", $._expression),
          ),
        ),
        prec.left(
          1,
          seq(
            field("left", $._expression),
            choice("or", "Or", "OR"),
            field("right", $._expression),
          ),
        ),
        prec.left(
          1,
          seq(
            field("left", $._expression),
            "&&",
            field("right", $._expression),
          ),
        ),
        prec.left(
          1,
          seq(
            field("left", $._expression),
            "||",
            field("right", $._expression),
          ),
        ),
        // Comparison
        prec.left(
          2,
          seq(
            field("left", $._expression),
            "==",
            field("right", $._expression),
          ),
        ),
        prec.left(
          2,
          seq(
            field("left", $._expression),
            "!=",
            field("right", $._expression),
          ),
        ),
        prec.left(
          2,
          seq(
            field("left", $._expression),
            ">=",
            field("right", $._expression),
          ),
        ),
        prec.left(
          2,
          seq(
            field("left", $._expression),
            "<=",
            field("right", $._expression),
          ),
        ),
        prec.left(
          2,
          seq(field("left", $._expression), ">", field("right", $._expression)),
        ),
        prec.left(
          2,
          seq(field("left", $._expression), "<", field("right", $._expression)),
        ),
        prec.left(
          2,
          seq(field("left", $._expression), "=", field("right", $._expression)),
        ),
        // Addition / Subtraction
        prec.left(
          3,
          seq(field("left", $._expression), "+", field("right", $._expression)),
        ),
        prec.left(
          3,
          seq(field("left", $._expression), "-", field("right", $._expression)),
        ),
        // Multiplication / Division
        prec.left(
          4,
          seq(field("left", $._expression), "*", field("right", $._expression)),
        ),
        prec.left(
          4,
          seq(field("left", $._expression), "/", field("right", $._expression)),
        ),
        // Exponentiation
        prec.right(
          5,
          seq(field("left", $._expression), "^", field("right", $._expression)),
        ),
      ),

    unary_expression: ($) => prec(6, seq(choice("-", "!"), $._expression)),

    // ─── Primary Expression ───────────────────────────────────
    primary_expression: ($) =>
      choice(
        $.number,
        $.string,
        $.boolean,
        $.list_literal,
        $.identifier,
        $.function_call,
        $.member_expression,
        $.subscript_expression,
      ),

    // ─── Function Call ────────────────────────────────────────
    function_call: ($) =>
      prec(
        8,
        seq(
          field("function", choice($.identifier, $.member_expression)),
          "(",
          field("arguments", optional($.argument_list)),
          ")",
        ),
      ),

    argument_list: ($) => seq($._expression, repeat(seq(",", $._expression))),

    // ─── Member Expression ────────────────────────────────────
    member_expression: ($) =>
      prec(
        9,
        seq(
          field(
            "object",
            choice(
              $.identifier,
              $.member_expression,
              $.subscript_expression,
              $.function_call,
              $.string,
            ),
          ),
          ".",
          field("property", $.identifier),
        ),
      ),

    // ─── Subscript Expression ─────────────────────────────────
    subscript_expression: ($) =>
      prec(
        9,
        seq(
          field(
            "object",
            choice($.identifier, $.member_expression, $.subscript_expression),
          ),
          "[",
          field("index", $._expression),
          "]",
        ),
      ),

    // ─── List Literal ─────────────────────────────────────────
    list_literal: ($) =>
      seq(
        "[",
        optional(seq($._expression, repeat(seq(",", $._expression)))),
        "]",
      ),

    // ─── Literals ─────────────────────────────────────────────
    number: ($) => token(choice(/\d+\.\d+/, /\d+/)),

    string: ($) =>
      choice(
        seq('"', optional($.string_content), '"'),
        seq("'", optional($.string_content_single), "'"),
      ),

    string_content: ($) => /[^"]+/,
    string_content_single: ($) => /[^']+/,

    boolean: ($) => choice("True", "true", "TRUE", "False", "false", "FALSE"),

    // ─── Identifier ───────────────────────────────────────────
    identifier: ($) => /[a-zA-Z_][a-zA-Z0-9_]*/,
  },
});
